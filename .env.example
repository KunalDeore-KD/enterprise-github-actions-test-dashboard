# GitHub Personal Access Token — needs repo + actions:write scope
GITHUB_TOKEN=your_github_pat_here
# Alias supported by the dashboard server
GITHUB_PAT=your_github_pat_here

# GitHub repo owner (username or org) — overridden by dashboard.config.json when present
GITHUB_OWNER=your_username

# GitHub repo name — overridden by dashboard.config.json when present
GITHUB_REPO=your_repo_name

# Port for the Express API server — overridden by dashboard.config.json when present
SERVER_PORT=5000

# Port for the static dashboard — overridden by dashboard.config.json when present
DASHBOARD_PORT=3000
